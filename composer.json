{
    "name": "scabo/coleo-model",
    "description": "Building the persistence layer for PHP application",
    "type": "library",
    "license": "MIT",
    "version": "0.0.1",
    "authors": [
        {
            "name": "Sergey Shevyakov",
            "email": "scabo.dev@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Coleo\\Model\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ColeoTest\\Model\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "doctrine/dbal": "^4.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.2",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "*"
    },
    "scripts": {
        "test": "vendor/bin/phpunit  --display-warnings",
        "inspect": "vendor/bin/phpstan analyse",
        "style_check": "vendor/bin/phpcs",
        "style_fix": "vendor/bin/phpcbf"
    }
}
